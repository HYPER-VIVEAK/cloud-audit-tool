# Cloud Audit Tool runtime configuration
# Fill these with your real values before running docker compose.
#npm run dev -- --host 0.0.0.0
# --- Auth & API ---
APP_NAME=Cloud Audit API
API_PREFIX=/api
SESSION_COOKIE_NAME=session_token
SESSION_COOKIE_SECURE=false
SESSION_DAYS=7
CREDENTIALS_SECRET=change-this-credentials-secret
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# --- AWS defaults ---
AWS_REGION=us-east-1

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false

# --- Reporting ---
REPORT_OUTPUT_DIR=./reports

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=cloud_audit_db
MYSQL_USER=mysqladmin
MYSQL_PASSWORD=mysqlpassword
MYSQL_HOST=mysql
MYSQL_PORT=3306

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=mongopassword
MONGO_INITDB_DATABASE=mongoappdb
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_SCAN_COLLECTION=scan_results

# --- Scan metadata ---
SCAN_PLATFORM=AWS
SCAN_ENVIRONMENT=Prod
