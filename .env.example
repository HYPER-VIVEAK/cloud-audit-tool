# Session auth
SESSION_COOKIE_NAME=session_token
SESSION_COOKIE_SECURE=false
SESSION_DAYS=7
CREDENTIALS_SECRET=change-this-credentials-secret
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# AWS
AWS_REGION=us-east-1

# App
APP_NAME=Cloud Audit API
API_PREFIX=/api

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=cloud_audit_db
MYSQL_USER=mysqladmin
MYSQL_PASSWORD=mysqlpassword
MYSQL_HOST=mysql
MYSQL_PORT=3306

# MongoDB
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=mongopassword
MONGO_INITDB_DATABASE=mongoappdb
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_SCAN_COLLECTION=scan_results

# Scan metadata
SCAN_PLATFORM=AWS
SCAN_ENVIRONMENT=Prod
